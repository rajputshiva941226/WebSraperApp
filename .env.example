# Journal Scraper — Environment Variables Template
# Copy this to .env and fill in values for your EC2 instance.
# Never commit .env to git.

# ---- Flask ----
SECRET_KEY=replace-with-a-long-random-string-here
UPLOAD_FOLDER=results
DATA_FOLDER=data

# ---- Database ----
# PostgreSQL (production EC2):
DATABASE_URL=postgresql://scraper_user:your_password@localhost/journal_scraper
# SQLite (local dev fallback — comment out DATABASE_URL above to use this):
# DATABASE_URL=sqlite:///journal_scraper.db

# ---- Celery / Redis ----
# Install Redis: sudo apt install redis-server && sudo systemctl enable redis
REDIS_URL=redis://localhost:6379/0

# ---- Optional ----
# FLASK_ENV=production
# FLASK_DEBUG=0
